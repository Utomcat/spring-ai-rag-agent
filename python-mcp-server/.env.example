# MCP Server Configuration Example
# Copy this file to .env and modify the values as needed

# ========== MCP Server 配置 ==========

# Server host address (127.0.0.1 for local, 0.0.0.0 for remote access)
MCP_HOST=127.0.0.1

# Server port number (1-65535)
MCP_PORT=8084

# Transport mode: stdio, sse, or streamable-http
MCP_TRANSPORT=stdio

# URL mount path (only used for sse or streamable-http)
MCP_MOUNT_PATH=/mcp

# ========== 日志配置 ==========

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========== 搜索功能配置 ==========

# HTTP 连接超时时间（秒）
SEARCH_CONNECT_TIMEOUT=5

# HTTP 读取超时时间（秒）
SEARCH_READ_TIMEOUT=10

# 最大重试次数
SEARCH_MAX_RETRIES=2

# 重试退避因子（指数退避：wait_time = factor ^ attempt）
SEARCH_RETRY_BACKOFF=1.5

# ========== Redis 缓存配置 ==========

# Redis 服务器地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码 (可选,如果没有密码留空)
REDIS_PASSWORD=

# Redis 连接超时时间(秒)
REDIS_TIMEOUT=5

# 是否启用 Redis 缓存 (true/false)
REDIS_CACHE_ENABLED=true

# 最大连接数
REDIS_MAX_CONNECTIONS=20

# ==================== 双 DB 架构配置 ====================

# 热点数据数据库编号 (推荐: 1)
REDIS_HOT_DATA_DB=1

# 完整数据数据库编号 (推荐: 2)
REDIS_FULL_DATA_DB=2

# 热点数据缓存最大条目数
HOT_DATA_CACHE_MAX_SIZE=50

# 热点数据 TTL (秒, 较短以提高命中率)
HOT_DATA_CACHE_TTL=300

# 完整数据缓存最大条目数
FULL_DATA_CACHE_MAX_SIZE=500

# 完整数据 TTL (秒, 较长以保留历史)
FULL_DATA_CACHE_TTL=1800

# ==================== 缓存预热配置 ====================

# 是否启用缓存预热 (true/false)
CACHE_WARMER_ENABLED=false

# 预热缓存键列表 (逗号分隔, 格式: type:url|query)
CACHE_WARMER_KEYS=

# ==================== 监控配置 ====================

# 是否启用缓存监控 (true/false)
CACHE_MONITOR_ENABLED=false

# Prometheus 监控端口
PROMETHEUS_PORT=9090

# ==================== 多实例同步配置 ====================

# 是否启用多实例同步 (true/false)
CACHE_SYNC_ENABLED=false

# 同步频道名称
CACHE_SYNC_CHANNEL=mcp-cache-sync

# ==================== 热点数据追踪配置 ====================

# 是否启用热点数据追踪 (true/false)
HOT_DATA_TRACKER_ENABLED=false

# 热点数据阈值 (访问次数)
HOT_DATA_THRESHOLD=10

# 热点数据窗口期 (秒)
HOT_DATA_WINDOW=3600

# 热点数据晋升检查间隔 (秒)
HOT_DATA_PROMOTION_INTERVAL=300

# ==================== 环境标识 ====================

# 环境标识 (dev/test/prod) - 用于日志和监控区分
APP_ENVIRONMENT=dev
