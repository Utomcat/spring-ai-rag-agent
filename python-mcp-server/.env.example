# MCP Server Configuration Example
# Copy this file to .env and modify the values as needed

# Server host address
MCP_HOST=0.0.0.0

# Server port number
MCP_PORT=8084

# Transport mode: stdio, sse, or streamable-http
MCP_TRANSPORT=stdio

# URL mount path (only used for sse or streamable-http)
MCP_MOUNT_PATH=
