# MCP Server Configuration
# Copy from .env.example and modify the values as needed

# ========== MCP Server 配置 ==========

# Server host address (127.0.0.1 for local, 0.0.0.0 for remote access)
MCP_HOST=127.0.0.1

# Server port number (1-65535)
MCP_PORT=8084

# Transport mode: stdio, sse, or streamable-http
MCP_TRANSPORT=streamable-http

# URL mount path (only used for sse or streamable-http)
MCP_MOUNT_PATH=/mcp

# ========== 日志配置 ==========

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========== 搜索功能配置 ==========

# HTTP 连接超时时间（秒）
SEARCH_CONNECT_TIMEOUT=5

# HTTP 读取超时时间（秒）
SEARCH_READ_TIMEOUT=10

# 最大重试次数
SEARCH_MAX_RETRIES=2

# 重试退避因子（指数退避：wait_time = factor ^ attempt）
SEARCH_RETRY_BACKOFF=1.5
